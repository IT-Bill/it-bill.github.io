---
import FileEntry from "@/components/FileEntry.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import Prompt from "@/components/Prompt.astro";
import TerminalWindow from "@/components/TerminalWindow.astro";
import { Mail } from "@lucide/astro";
import type { PortfolioContent } from "@/types/portfolio";
import { getRelativeLocaleUrl } from "astro:i18n";

interface Props {
  content: PortfolioContent;
}

const { content } = Astro.props;
const { aboutLines, asciiArt, contactLinks, experiences, profile, projects, publications, researchFocus, statusLines, toolGroups } =
  content;
const countText = (template: string, count: number) => template.replace("{count}", String(count));
const homeHref = getRelativeLocaleUrl(content.locale);
const languageHref = getRelativeLocaleUrl(content.nav.languageTargetLocale);
const leadingStatusLines = statusLines.slice(0, -1);
const finalStatusLine = statusLines.at(-1);
const projectCategories = Array.from(new Set(projects.map((project) => project.category)));
const socialLabel = content.locale === "zh" ? "社交" : "SOCIAL";
const socialLinkOrder = ["github.com", "linkedin.com", "x.com", "mailto:"];
const socialLinks = [...contactLinks].sort(
  (a, b) => socialLinkOrder.findIndex((value) => a.href.includes(value)) - socialLinkOrder.findIndex((value) => b.href.includes(value)),
);
---

<div class="terminal-page">
  <nav class="term-nav">
    <div class="term-container term-nav__inner">
      <a href={homeHref} class="term-nav__brand"><span class="term-nav__brand-user">zhanwei@</span>it-bill:~$</a>
      <div class="term-nav__actions">
        <ul class="term-nav__links">
          {
            content.nav.items.map((item) => (
              <li>
                <a href={item.href} class="term-nav__link">
                  <span class="term-nav__label-full">{item.label}</span>
                  <span class="term-nav__label-short">{item.shortLabel}</span>
                </a>
              </li>
            ))
          }
        </ul>
        <a href={languageHref} class="language-command" aria-label={content.nav.languageAriaLabel}>
          <span class="language-command__prompt" aria-hidden="true">❯</span>
          <span class="language-command__name">{content.nav.languageCommand}</span>
          <span class="language-command__flag">{content.nav.languageFlag}</span>
          <span class="language-command__flag language-command__flag--short">{content.nav.languageShortFlag}</span>
        </a>
        <button class="theme-command" type="button" data-theme-toggle-button aria-label={content.nav.themeAriaLabel}>
          <span class="theme-command__prompt" aria-hidden="true">❯</span>
          <span class="theme-command__name">style</span>
          <span class="theme-command__flag" data-theme-label>--light</span>
          <span class="theme-command__flag theme-command__flag--short" data-theme-label-short>--lt</span>
        </button>
      </div>
    </div>
  </nav>

  <main>
    <section class="term-section term-section--hero" id="hero">
      <div class="term-container">
        <div class="hero-boot">
          <div class="hero-layout">
            <div class="hero-layout__identity">
              <div class="hero-boot__content">
                <div class="hero-avatar">
                  <img
                    src={profile.avatar.src}
                    alt={profile.avatar.alt}
                    width={profile.avatar.width}
                    height={profile.avatar.height}
                    class="hero-avatar__img"
                    loading="eager"
                    decoding="async"
                    fetchpriority="high"
                  />
                </div>
                <div class="hero-ascii-wrapper">
                  <div class="ascii-lockup" aria-hidden="true">
                    <pre class="ascii-art ascii-art--first">{asciiArt.firstName}</pre>
                    <pre class="ascii-art ascii-art--last">{asciiArt.lastName}</pre>
                  </div>
                  <h1 class="visually-hidden">{profile.name}</h1>
                </div>
              </div>

              <div class="hero-status stagger-in">
                {
                  leadingStatusLines.map((line) => (
                    <div class="status-line">
                      <span class="status-label">{line.label}</span>
                      <span class="status-ok">[OK]</span>
                      <span class={line.tone}>{line.text}</span>
                    </div>
                  ))
                }
                {
                  finalStatusLine ? (
                    <div class="status-line">
                      <span class="status-label">{finalStatusLine.label}</span>
                      <span class="status-ok">[OK]</span>
                      <span class={finalStatusLine.tone}>{finalStatusLine.text}</span>
                    </div>
                  ) : null
                }
                <div class="status-line status-line--social">
                  <span class="status-label">{socialLabel}</span>
                  <span class="status-ok">[OK]</span>
                  <div class="hero-socials">
                    <span class="hero-socials__command" aria-hidden="true">$ open ./</span>
                    <nav class="hero-socials__links" aria-label={socialLabel}>
                      {
                        socialLinks.map((link) => (
                          <a
                            href={link.href}
                            target={link.href.startsWith("mailto:") ? undefined : "_blank"}
                            rel={link.href.startsWith("mailto:") ? undefined : "noopener noreferrer"}
                            class="hero-social-link"
                            aria-label={link.label}
                            data-label={link.label}
                          >
                            {link.href.includes("github.com") ? (
                              <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.4 5.4 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
                                <path d="M9 18c-4.51 2-5-2-7-2" />
                              </svg>
                            ) : link.href.includes("linkedin.com") ? (
                              <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6Z" />
                                <path d="M2 9h4v12H2z" />
                                <circle cx="4" cy="4" r="2" />
                              </svg>
                            ) : link.href.includes("x.com") ? (
                              <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M18.244 2H21.552l-7.227 8.26L22.827 22h-6.657l-5.214-6.817L4.99 22H1.68l7.73-8.835L1.254 2H8.08l4.713 6.231L18.244 2Zm-1.161 17.932h1.833L7.084 3.966H5.117l11.966 15.966Z" fill="currentColor" stroke="none" />
                              </svg>
                            ) : (
                              <Mail aria-hidden="true" />
                            )}
                          </a>
                        ))
                      }
                    </nav>
                  </div>
                </div>
                <div class="status-line status-line--ready">
                  <span class="term-text-bright">{content.terminal.ready}</span>
                  <span class="cursor"></span>
                </div>
              </div>
            </div>

            <aside class="hero-side" aria-label={`${content.heroResume.label} ${content.heroEducation.title}`}>
              <section class="hero-panel hero-resume-panel">
                <div class="hero-panel__command">
                  <span class="term-text-amber">$</span>
                  <span>{content.heroResume.command}</span>
                </div>
                <div class="hero-panel__header">
                  <span class="hero-panel__title">{content.heroResume.label}</span>
                </div>
                <div class="hero-resume-links">
                  {
                    content.heroResume.links.map((link) => (
                      <a
                        href={link.href}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="hero-resume-link"
                        aria-label={link.ariaLabel}
                      >
                        <span class="hero-resume-link__label">{link.label}</span>
                        <span class="hero-resume-link__command">{link.command}</span>
                      </a>
                    ))
                  }
                </div>
              </section>

              <section class="hero-panel hero-education">
                <div class="hero-panel__command">
                  <span class="term-text-amber">$</span>
                  <span>{content.heroEducation.command}</span>
                </div>
                <div class="hero-panel__header">
                  <span class="hero-panel__title">{content.heroEducation.title}</span>
                </div>
                <div class="hero-education__list">
                  {
                    content.heroEducation.items.map((item) => (
                      <article class="hero-education__item">
                        <div class="hero-education__item-main">
                          <h2 class="hero-education__degree">{item.degree}</h2>
                          <p class="hero-education__institution">{item.institution}</p>
                        </div>
                        <span class="hero-education__period">{item.period}</span>
                      </article>
                    ))
                  }
                </div>
              </section>
            </aside>
          </div>
        </div>
      </div>
    </section>

    <section class="term-section" id="about">
      <div class="term-container">
        <TerminalWindow title="zhanwei@it-bill: ~/about">
          <Prompt path="~/about" command="whoami" />
          <div class="output">
            <span class="output__line output__line--name term-text-bright">{profile.name}</span>
            <span class="output__line term-text">{profile.tagline}</span>
            <span class="output__line term-text-dim">// {profile.location}</span>
            <span class="output__line term-text-dim">// {profile.email}</span>
          </div>

          <Prompt path="~/about" command="cat ./summary.txt" spaced />
          <div class="output output--indented output--copy">
            {aboutLines.map((line) => <span class="output__line term-text-white">{line}</span>)}
          </div>

          <Prompt path="~/about" command="cat ./research-focus.txt" spaced />
          <div class="output output--indented output--copy">
            {
              researchFocus.map((line) => (
                <span class="output__line">
                  <span class="term-text-amber">→</span> <span class="term-text-white">{line}</span>
                </span>
              ))
            }
          </div>

          <Prompt path="~/about" command="ls ./skills" spaced />
          <div class="skills-icon-grid">
            {
              toolGroups.map((group) => (
                <section class="skills-icon-group">
                  <div class="skills-icon-group__header">
                    <h2 class="skills-icon-group__title">{group.title}</h2>
                    {group.description ? (
                      <span class="skills-help" tabindex="0" aria-label={group.description}>
                        ?
                        <span class="skills-help__bubble">{group.description}</span>
                      </span>
                    ) : null}
                  </div>
                  <div class="skills-icon-group__items">
                    {group.items.map((item) => (
                      <img
                        src={`https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/${item.icon}.svg`}
                        alt={item.name}
                        title={item.name}
                        class="skills-icon-group__icon"
                        loading="lazy"
                        decoding="async"
                      />
                    ))}
                  </div>
                </section>
              ))
            }
          </div>
        </TerminalWindow>
      </div>
    </section>

    <section class="term-section" id="experiences">
      <div class="term-container">
        <TerminalWindow title="zhanwei@it-bill: ~/experiences">
          <Prompt path="~/experiences" command="cat ./timeline.log" />
          <div class="timeline">
            {
              experiences.map((experience) => (
                <article class="timeline-entry">
                  <div class="timeline-entry__marker">{experience.type}</div>
                  <div class="timeline-entry__body">
                    <div class="timeline-entry__header">
                      <h2 class="timeline-entry__title">{experience.title}</h2>
                      <span class="timeline-entry__period">{experience.period}</span>
                    </div>
                    <p class="timeline-entry__institution">{experience.institution}</p>
                    <div class="timeline-entry__description">
                      {experience.description.map((line) => (
                        <span class="output__line term-text-white">{line}</span>
                      ))}
                    </div>
                    <div class="project-card__tags">
                      {experience.tags.map((tag) => <span class="project-card__tag">{tag}</span>)}
                    </div>
                  </div>
                </article>
              ))
            }
          </div>
        </TerminalWindow>
      </div>
    </section>

    <section class="term-section" id="publications">
      <div class="term-container">
        <TerminalWindow title="zhanwei@it-bill: ~/publications">
          <Prompt path="~/publications" command="ls -la ./papers" />
          <div class="output output--project-count">
            <span class="output__line term-text-dim">{countText(content.terminal.totalPublications, publications.length)}</span>
          </div>
          <div class="publication-list">
            {
              publications.map((publication) => (
                <article class="publication-card">
                  <div class="publication-card__header">
                    <h2 class="publication-card__title">{publication.title}</h2>
                    <span class="publication-card__year">{publication.year}</span>
                  </div>
                  <p class="publication-card__venue">{publication.venue}</p>
                  <p class="publication-card__authors">{publication.authors.join(", ")}</p>
                  <p class="publication-card__description">{publication.description}</p>
                  <div class="project-card__links">
                    {publication.paperUrl ? (
                      <a href={publication.paperUrl} target="_blank" rel="noopener noreferrer" class="project-card__link">
                        <span>→ ./open --paper</span>
                      </a>
                    ) : null}
                    {publication.repoUrl ? (
                      <a href={publication.repoUrl} target="_blank" rel="noopener noreferrer" class="project-card__link">
                        <span>→ ./open --code</span>
                      </a>
                    ) : null}
                  </div>
                </article>
              ))
            }
          </div>
        </TerminalWindow>
      </div>
    </section>

    <section class="term-section" id="projects">
      <div class="term-container">
        <TerminalWindow title="zhanwei@it-bill: ~/projects">
          <Prompt path="~/projects" command="ls -la | filter --category" />
          <div class="project-filters" data-project-filter-group>
            <button
              type="button"
              class="project-filter is-active"
              data-project-filter="__all"
              aria-pressed="true"
            >
              <span>{content.terminal.projectFilterAll}</span>
            </button>
            {
              projectCategories.map((category) => (
                <button type="button" class="project-filter" data-project-filter={category} aria-pressed="false">
                  <span>{category}</span>
                </button>
              ))
            }
          </div>
          <div class="output output--project-count">
            <span class="output__line term-text-dim" data-project-count data-project-count-template={content.terminal.totalProjects}>
              {countText(content.terminal.totalProjects, projects.length)}
            </span>
          </div>
          <div class="file-list">
            {projects.map((project) => <FileEntry project={project} loadingText={content.terminal.loadingImage} />)}
          </div>
          <div class="project-card-grid">
            {projects.map((project) => <ProjectCard project={project} privateAccess={content.terminal.privateAccess} />)}
          </div>
        </TerminalWindow>
      </div>
    </section>

    <section class="term-section term-section--full" id="contact">
      <div class="term-container">
        <TerminalWindow title="zhanwei@it-bill: ~/contact">
          <Prompt path="~/contact" command="cat ./links.txt" />
          <div class="output output--indented stagger-in">
            <span class="output__line output__line--loose">
              <span class="term-text-dim copy-text">// {content.terminal.contactComment}</span>
            </span>
            {
              contactLinks.map((link) => (
                <span class="output__line">
                  <span class="term-text-amber">{link.label.toUpperCase()}</span>
                  <span class="term-text-dim"> → </span>
                  <a
                    href={link.href}
                    target={link.href.startsWith("mailto:") ? undefined : "_blank"}
                    rel={link.href.startsWith("mailto:") ? undefined : "noopener noreferrer"}
                    class="term-link"
                  >
                    {link.value}
                  </a>
                </span>
              ))
            }
          </div>
          <Prompt path="~/contact" command={content.contactComposer.command} spaced />
          <form
            class="mail-composer"
            data-mail-composer
            data-recipient={profile.email}
            data-mailto-status={content.contactComposer.mailtoStatus}
            data-copied-status={content.contactComposer.copiedStatus}
            data-copy-failed-status={content.contactComposer.copyFailedStatus}
          >
            <div class="mail-composer__row mail-composer__row--to">
              <span class="mail-composer__label">{content.contactComposer.toLabel}</span>
              <a href={`mailto:${profile.email}`} class="mail-composer__address">{profile.email}</a>
            </div>
            <label class="mail-composer__field">
              <span class="mail-composer__label">{content.contactComposer.subjectLabel}</span>
              <input
                type="text"
                class="mail-composer__input"
                name="subject"
                placeholder={content.contactComposer.subjectPlaceholder}
                autocomplete="off"
                data-mail-subject
              />
            </label>
            <label class="mail-composer__field">
              <span class="mail-composer__label">{content.contactComposer.messageLabel}</span>
              <textarea
                class="mail-composer__textarea"
                name="body"
                rows="5"
                placeholder={content.contactComposer.messagePlaceholder}
                data-mail-body></textarea>
            </label>
            <div class="mail-composer__actions">
              <a href={`mailto:${profile.email}`} class="mail-composer__button mail-composer__button--primary" data-mail-send>
                <span class="mail-composer__button-prompt">❯</span>
                <span>{content.contactComposer.sendLabel}</span>
              </a>
              <button type="button" class="mail-composer__button" data-copy-email>
                <span class="mail-composer__button-prompt">❯</span>
                <span>{content.contactComposer.copyLabel}</span>
              </button>
              <span class="mail-composer__status" aria-live="polite" data-mail-status></span>
            </div>
          </form>
          <Prompt path="~/contact" cursor spaced />
        </TerminalWindow>
      </div>
    </section>

    <footer class="term-section term-section--full term-footer">
      <div class="term-container">
        <div class="term-footer__inner">
          <span class="term-text-dim">
            <span class="term-comment">{content.terminal.builtWith}</span>
          </span>
          <span class="term-text-dim">© 2026 {profile.name}</span>
        </div>
      </div>
    </footer>
  </main>
</div>
