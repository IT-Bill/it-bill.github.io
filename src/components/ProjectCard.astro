---
import type { Project } from "@/types/portfolio";

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<div id={project.id} class="project-card">
  <div class="project-card__header">
    <span class="project-card__title">
      <span class="term-text-amber">$</span> cat ./{project.slug}/README.md
    </span>
    <span class="project-card__meta">{project.period}</span>
  </div>
  <div class="project-card__body">
    <div class="project-card__image-container">
      <img
        src={project.image.src}
        alt={project.image.alt}
        width={project.image.width}
        height={project.image.height}
        class="project-card__image"
        loading="eager"
        decoding="async"
      />
    </div>
    <h3 class="project-card__heading">{project.title}</h3>
    <div class="project-card__meta-line">
      <span>{project.category}</span>
      <span>{project.year}</span>
    </div>
    <p class="project-card__description">{project.description}</p>
    <div class="project-card__tags">
      {project.techStack.map((tag) => <span class="project-card__tag">{tag}</span>)}
    </div>
    {
      project.links.length > 0 ? (
        <div class="project-card__links">
          {project.links.map((link) => (
            <a href={link.href} target="_blank" rel="noopener noreferrer" class="project-card__link">
              <span>→ ./open --{link.label.toLowerCase()}</span>
            </a>
          ))}
        </div>
      ) : (
        <span class="project-card__private">./access --private</span>
      )
    }
  </div>
</div>
