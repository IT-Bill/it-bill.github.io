---
import TerminalEffects from "@/components/TerminalEffects.astro";
import TerminalPortfolio from "@/components/TerminalPortfolio.astro";
import { portfolioContent } from "@/data/portfolio";
import BaseLayout from "@/layouts/BaseLayout.astro";

const content = portfolioContent.zh;
---

<BaseLayout lang={content.htmlLang} title={content.meta.title} description={content.meta.description} image={content.meta.image}>
  <TerminalEffects />
  <TerminalPortfolio content={content} />
</BaseLayout>
